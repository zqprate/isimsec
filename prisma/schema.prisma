// İsimSeç — Prisma Schema
// Supabase PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════
// İsimler ana tablosu
// ═══════════════════════════════════════

model Name {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique @db.VarChar(255)
  name           String   @db.VarChar(255)
  gender         String   @db.VarChar(20) // male | female | unisex
  syllableCount  Int?     @map("syllable_count") @db.SmallInt
  letterCount    Int?     @map("letter_count") @db.SmallInt
  startingLetter String?  @map("starting_letter") @db.Char(1)
  endingLetter   String?  @map("ending_letter") @db.Char(1)
  isPopular      Boolean  @default(false) @map("is_popular")
  popularityRank Int?     @map("popularity_rank")
  searchCount    Int      @default(0) @map("search_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  translations NameTranslation[]
  nameOrigins  NameOrigin[]
  nameMeanings NameMeaningCategory[]
  favorites    Favorite[]

  @@index([gender], name: "idx_names_gender")
  @@index([startingLetter], name: "idx_names_starting_letter")
  @@index([popularityRank], name: "idx_names_popularity")
  @@index([slug], name: "idx_names_slug")
  @@map("names")
}

// ═══════════════════════════════════════
// İsim çevirileri (çok dilli)
// ═══════════════════════════════════════

model NameTranslation {
  id              String   @id @default(uuid()) @db.Uuid
  nameId          String   @map("name_id") @db.Uuid
  locale          String   @db.VarChar(5)
  meaning         String
  description     String?
  pronunciation   String?  @db.VarChar(255)
  famousPeople    String[] @map("famous_people")
  culturalNotes   String?  @map("cultural_notes")
  metaTitle       String?  @map("meta_title") @db.VarChar(70)
  metaDescription String?  @map("meta_description") @db.VarChar(160)

  name Name @relation(fields: [nameId], references: [id], onDelete: Cascade)

  @@unique([nameId, locale])
  @@index([locale], name: "idx_name_translations_locale")
  @@index([nameId, locale], name: "idx_name_translations_name_locale")
  @@map("name_translations")
}

// ═══════════════════════════════════════
// Kökenler
// ═══════════════════════════════════════

model Origin {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  translations OriginTranslation[]
  nameOrigins  NameOrigin[]

  @@map("origins")
}

model OriginTranslation {
  id          String  @id @default(uuid()) @db.Uuid
  originId    String  @map("origin_id") @db.Uuid
  locale      String  @db.VarChar(5)
  name        String  @db.VarChar(100)
  description String?

  origin Origin @relation(fields: [originId], references: [id], onDelete: Cascade)

  @@unique([originId, locale])
  @@map("origin_translations")
}

// ═══════════════════════════════════════
// İsim–Köken ilişkisi (many-to-many)
// ═══════════════════════════════════════

model NameOrigin {
  nameId   String @map("name_id") @db.Uuid
  originId String @map("origin_id") @db.Uuid

  name   Name   @relation(fields: [nameId], references: [id], onDelete: Cascade)
  origin Origin @relation(fields: [originId], references: [id], onDelete: Cascade)

  @@id([nameId, originId])
  @@map("name_origins")
}

// ═══════════════════════════════════════
// Anlam kategorileri
// ═══════════════════════════════════════

model MeaningCategory {
  id   String @id @default(uuid()) @db.Uuid
  slug String @unique @db.VarChar(100)

  translations MeaningCategoryTranslation[]
  nameMeanings NameMeaningCategory[]

  @@map("meaning_categories")
}

model MeaningCategoryTranslation {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  locale     String @db.VarChar(5)
  name       String @db.VarChar(100)

  category MeaningCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("meaning_category_translations")
}

// ═══════════════════════════════════════
// İsim–Anlam ilişkisi (many-to-many)
// ═══════════════════════════════════════

model NameMeaningCategory {
  nameId     String @map("name_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  name     Name            @relation(fields: [nameId], references: [id], onDelete: Cascade)
  category MeaningCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([nameId, categoryId])
  @@map("name_meaning_categories")
}

// ═══════════════════════════════════════
// Kullanıcı favorileri
// ═══════════════════════════════════════

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.VarChar(255)
  nameId    String   @map("name_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  name Name @relation(fields: [nameId], references: [id], onDelete: Cascade)

  @@unique([sessionId, nameId])
  @@index([sessionId], name: "idx_favorites_session")
  @@map("favorites")
}

// ═══════════════════════════════════════
// Blog yazıları
// ═══════════════════════════════════════

model BlogPost {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @db.VarChar(255)
  locale        String    @db.VarChar(5)
  title         String    @db.VarChar(255)
  content       String
  excerpt       String?
  featuredImage String?   @map("featured_image") @db.VarChar(500)
  published     Boolean   @default(false)
  publishedAt   DateTime? @map("published_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([slug, locale])
  @@map("blog_posts")
}
